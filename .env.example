# ============================================================
#  DevStream — Environment Variables
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ============================================================

# ------------------------------------------------------------
#  Dev.to Configuration
#  Your Dev.to username (used to fetch articles from the API)
#  Find it at: https://dev.to/settings
# ------------------------------------------------------------
VITE_DEVTO_USERNAME=gouranga-das-khulna

# Dev.to API Key (optional — only needed for private/draft articles)
# Generate at: https://dev.to/settings/extensions → DEV Community API Keys
VITE_DEVTO_API_KEY=

# ------------------------------------------------------------
#  Algolia Search (optional)
#  Required only if you want to replace local search with
#  Algolia InstantSearch. Leave blank to use built-in search.
#
#  Setup steps:
#  1. Create a free account at https://www.algolia.com
#  2. Create an index named e.g. "devstream_articles"
#  3. Index your Dev.to articles (run the indexing script)
#  4. Copy your App ID and Search-Only API key below
# ------------------------------------------------------------
VITE_ALGOLIA_APP_ID=
VITE_ALGOLIA_SEARCH_KEY=
VITE_ALGOLIA_INDEX_NAME=devstream_articles

# ------------------------------------------------------------
#  Site Metadata (used in <head> and Open Graph tags)
# ------------------------------------------------------------
VITE_SITE_NAME=DevStream
VITE_SITE_URL=https://your-deployed-url.com
VITE_SITE_DESCRIPTION=Gouranga Das Samrat's dev blog — powered by Dev.to

# ------------------------------------------------------------
#  Social Links
# ------------------------------------------------------------
VITE_GITHUB_URL=https://github.com/GourangaDasSamrat
VITE_LINKEDIN_URL=https://www.linkedin.com/in/gouranga-das-samrat/
VITE_DEVTO_PROFILE_URL=https://dev.to/gouranga-das-khulna

# ------------------------------------------------------------
#  Pagination Defaults (optional overrides)
# ------------------------------------------------------------
VITE_DEFAULT_PER_PAGE=9
